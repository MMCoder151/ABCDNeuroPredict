fit_df["recording_end_date"] = fit_df["recording_end"].dt.date
fit_df["mri_date_date"] = fit_df["mri_date"].dt.date

# check if recording start and end dates are consistent within subjects and timepoints
if fit_df.groupby(["subject", "timepoint"])["recording_start_date"].nunique().max() > 1:
    print("Inconsistent recording start dates found.")
if fit_df.groupby(["subject", "timepoint"])["recording_end_date"].nunique().max() > 1:
    print("Inconsistent recording end dates found.")

# ------------------------------------------------------------------
# ---- Exploratory analysis into recording duration missmatches ----
# ------------------------------------------------------------------
# get difference between max and min recording start and end times per subject and timepoint
fit_df["recording_start_diff"] = fit_df.groupby(["subject", "timepoint"])["recording_start"].transform(lambda x: (x.max() - x.min()).total_seconds() / 3600)
fit_df["recording_end_diff"] = fit_df.groupby(["subject", "timepoint"])["recording_end"].transform(lambda x: (x.max() - x.min()).total_seconds() / 3600)
recording_diff = fit_df.groupby(["subject", "timepoint"])[["recording_start_diff", "recording_end_diff"]].max().reset_index()
print(recording_diff)

# get difference between max and min recording start and end dates per subject and timepoint
fit_df["recording_start_date_diff"] = fit_df.groupby(["subject", "timepoint"])["recording_start_date"].transform(lambda x: (x.max() - x.min()).days)
fit_df["recording_end_date_diff"] = fit_df.groupby(["subject", "timepoint"])["recording_end_date"].transform(lambda x: (x.max() - x.min()).days)
recording_diff = fit_df.groupby(["subject", "timepoint"])[["recording_start_date_diff", "recording_end_date_diff"]].max().reset_index()
print(recording_diff)

# keep datetime dtype
fit_df["recording_start"] = pd.to_datetime(fit_df["recording_start"], errors="coerce")
fit_df["recording_end"] = pd.to_datetime(fit_df["recording_end"], errors="coerce")

# Timedelta per subject/timepoint
fit_df["recording_start_diff"] = fit_df.groupby(
    ["subject", "timepoint"]
)["recording_start"].transform(lambda x: x.max() - x.min())

fit_df["recording_end_diff"] = fit_df.groupby(
    ["subject", "timepoint"]
)["recording_end"].transform(lambda x: x.max() - x.min())

recording_diff = fit_df.groupby(["subject", "timepoint"])[
    ["recording_start_diff", "recording_end_diff"]
].max().reset_index()

print(recording_diff)

# create subset of fit_df without "slp" files for further analysis
fit_df_wake = fit_df[~fit_df["filename"].str.contains("slp", case=False)]

# check if recording start and end times are consistent within subjects and timepoints for wake files
if fit_df_wake.groupby(["subject", "timepoint"])["recording_start_date"].nunique().max() > 1:
    print("Inconsistent recording start times found in wake files.")
else:    print("Recording start times are consistent in wake files.")   
if fit_df_wake.groupby(["subject", "timepoint"])["recording_end_date"].nunique().max() > 1:
    print("Inconsistent recording end times found in wake files.")
else:    print("Recording end times are consistent in wake files.")

# get filenames of fit files with max recording duration per subject and timetpoints
fit_df_wake["max_recording_duration"] = fit_df_wake.groupby(["subject", "timepoint"])["recording_duration"].transform("max")
fit_df_wake["max_recording_duration_file"] = fit_df_wake.apply(lambda row: row["filename"] if row["recording_duration"] == row["max_recording_duration"] else None, axis=1)
