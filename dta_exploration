from pathlib import Path
import pandas as pd
import os

# Set data directory paths
dta_path = Path.home() / "dairc" / "rawdata"
mri_path = dta_path / "phenotype"

# Set output path
output_path = os.path.join(os.getcwd(), "output")

# Read participant information and get subject folders
subs = pd.read_csv(dta_path / "participants.tsv", sep="\t")
sub_folders = [f for f in dta_path.iterdir() if f.name in subs["participant_id"].values]

## CHECK DATA AVAILABILITY

n_toal_subs = len(sub_folders)
print(f"Total number of subjects: {n_toal_subs}")

# Find files with "fit" in the name
fit_files = []

for sub_folder in sub_folders[:100]:
    sub_id = sub_folder.name
    
    # Search recursively for files with "fit" in the name
    for fit_file in sub_folder.rglob("*fit*"):
        if fit_file.is_file():
            # Extract timepoint/session from file path
            parts = fit_file.relative_to(sub_folder).parts
            timepoint = next((p for p in parts if p.startswith("ses-")), "unknown")
            
            fit_files.append({
                "subject": sub_id,
                "timepoint": timepoint,
                "filename": fit_file.name,
                "filepath": str(fit_file)
            })

# Convert to DataFrame for easy inspection
fit_df = pd.DataFrame(fit_files)

# get unique timepoints per subject for fit files
unique_timepoints = fit_df.groupby("subject")["timepoint"].unique().reset_index()
print(unique_timepoints)

n_fit_subs = fit_df["subject"].nunique()
print(f"Number of subjects with 'fit' files: {n_fit_subs}")
print(f"Average number of timepoints per subject with 'fit' files: {fit_df.groupby('subject')['timepoint'].nunique().mean():.2f}")

# Find "scans" files
scan_files = []

for sub_folder in sub_folders[:100]:
    sub_id = sub_folder.name
    
    # Search recursively for files with "scans" in the name
    for scan_file in sub_folder.rglob("*scans*"):
        if scan_file.is_file():
            # check if "acq_time" column is empty in the file, if so, skip the file
            temp_file = pd.read_csv(scan_file, sep="\t")
            if temp_file.empty:
                continue
            temp_file["acq_time"] = pd.to_datetime(temp_file["acq_time"], errors="coerce")
            if temp_file["acq_time"].isna().all():
                continue
            # Extract timepoint/session from file path
            parts = scan_file.relative_to(sub_folder).parts
            timepoint = next((p for p in parts if p.startswith("ses-")), "unknown")
            
            scan_files.append({
                "subject": sub_id,
                "timepoint": timepoint,
                "filename": scan_file.name,
                "filepath": str(scan_file)
            })
# Convert to DataFrame for easy inspection
scan_df = pd.DataFrame(scan_files)

print(f"Number of subjects with 'scans' files: {scan_df['subject'].nunique()}")
print(f"Average number of timepoints per subject with 'scans' files: {scan_df.groupby('subject')['timepoint'].nunique().mean():.2f}")

pd.set_option("display.max_columns", 4)
pd.set_option("display.max_rows", 10)
pd.set_option("display.width", 150)

# Get timepoints per subjects with both "fit" and "scans" files
fit_timepoints = fit_df.groupby("subject")["timepoint"].unique().reset_index()
scan_timepoints = scan_df.groupby("subject")["timepoint"].unique().reset_index()
merged_timepoints = pd.merge(fit_timepoints, scan_timepoints, on="subject", how="inner", suffixes=("_fit", "_scan"))
merged_timepoints["common_timepoints"] = merged_timepoints.apply(lambda row: set(row["timepoint_fit"]) & set(row["timepoint_scan"]), axis=1)
print(merged_timepoints[["subject", "common_timepoints"]])

# Keep only common fit and scan timepoints for further analysis
fit_df = fit_df.merge(merged_timepoints[["subject", "common_timepoints"]], left_on="subject", right_on="subject", how="inner")
fit_df = fit_df[fit_df.apply(lambda row: row["timepoint"] in row["common_timepoints"], axis=1)].drop(columns=["common_timepoints"])
scan_df = scan_df.merge(merged_timepoints[["subject", "common_timepoints"]], left_on="subject", right_on="subject", how="inner")
scan_df = scan_df[scan_df.apply(lambda row: row["timepoint"] in row["common_timepoints"], axis=1)].drop(columns=["common_timepoints"])

# check if all subjects contain the same amount of "fit" files per timepoint
fit_counts = fit_df.groupby(["subject", "timepoint"]).size().reset_index(name="fit_count")
print(fit_counts[fit_counts["fit_count"] != 7])
# drop timepoints with incomplete fit data
incomplete_timepoints = fit_counts[fit_counts["fit_count"] != 7][["subject", "timepoint"]]
fit_df = fit_df.merge(incomplete_timepoints, on=["subject", "timepoint"], how="left", indicator=True)
fit_df = fit_df[fit_df["_merge"] == "left_only"].drop(columns=["_merge"])
scan_df = scan_df.merge(incomplete_timepoints, on=["subject", "timepoint"], how="left", indicator=True)
scan_df = scan_df[scan_df["_merge"] == "left_only"].drop(columns=["_merge"])

print(f"Number of subjects with both 'fit' and 'scans' files: {fit_df['subject'].nunique()}")
# print how many timepoints are available per subject
timepoint_counts = fit_df.groupby("subject")["timepoint"].nunique().reset_index(name="timepoint_count")
print(f"Timepoint counts per subject:\n{timepoint_counts}")
# print how many subjects have more than 1 timepoint available
subjects_multiple_timepoints = timepoint_counts[timepoint_counts["timepoint_count"] > 1]
print(f"Subjects with multiple timepoints:\n{subjects_multiple_timepoints}")
# extract how many subjects have immediate follow-up timepoints


# CHECK DATA QUALITY
# Check recording duration per subject and timepoint
fit_df["recording_start"] = None
fit_df["recording_end"] = None
fit_df["recording_duration"] = None 

for file in fit_df["filepath"]:
    temp_file = pd.read_csv(file, sep="\t")
    if temp_file["Wear_Time"].dtype != "datetime64[ns]":
        temp_file["Wear_Time"] = pd.to_datetime(temp_file["Wear_Time"])
    fit_df.loc[fit_df["filepath"] == file, "recording_start"] = temp_file["Wear_Time"].min()
    fit_df.loc[fit_df["filepath"] == file, "recording_end"] = temp_file["Wear_Time"].max()
    duration = temp_file["Wear_Time"].max() - temp_file["Wear_Time"].min()
    fit_df.loc[fit_df["filepath"] == file, "recording_duration"] = duration

# Get wear time duration per subject and timepoint
wear_time_summary = fit_df.groupby(["subject", "timepoint"])["recording_duration"].agg(["mean"]).reset_index()
print(wear_time_summary)

# Check time between fit file recordings and MRI sessions
