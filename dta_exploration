recording_duration_diff = fit_df.groupby(["subject", "timepoint"])["recording_duration_diff"].max().reset_index()
print(recording_duration_diff)

# get names of fit files that deviate from the min recording duration by subject and timepoint
fit_df["min_recording_duration"] = fit_df.groupby(["subject", "timepoint"])["recording_duration"].transform("min")
fit_df["deviating_recording_duration_file"] = fit_df.apply(lambda row: row["filename"] if row["recording_duration"] != row["min_recording_duration"] else None, axis=1)

# Collect deviating filenames per group as a list
deviating_recording_duration_files = fit_df[fit_df["deviating_recording_duration_file"].notna()].groupby(["subject", "timepoint"])["deviating_recording_duration_file"].apply(list).reset_index()
deviating_recording_duration_files.rename(columns={"deviating_recording_duration_file": "deviating_files"}, inplace=True)
print(deviating_recording_duration_files)
deviating_recording_duration_files["count"] = deviating_recording_duration_files["deviating_files"].apply(len)
# print subjects and timepoints and count of deviating files
print(deviating_recording_duration_files[["subject", "timepoint", "count"]])

# get names of fit files that deviate from the max recording duration by subject and timepoint
