    fit_df.loc[(fit_df["subject"] == scan_df.loc[scan_df["filepath"] == file, "subject"].values[0]) & 
                (fit_df["timepoint"] == scan_df.loc[scan_df["filepath"] == file, "timepoint"].values[0]), "mri_date"] = mri_date

print(fit_df[["subject", "timepoint", "recording_start", "recording_end", "mri_date"]])
fit_df["time_to_mri"] = fit_df["mri_date"] - fit_df["recording_start"] 
print(fit_df.groupby(["subject", "timepoint"])["time_to_mri"].mean())

# extract recording start, end and mri calendar dates per subject and timepoint
fit_df["recording_start"] = pd.to_datetime(fit_df["recording_start"], errors="coerce")
fit_df["recording_end"] = pd.to_datetime(fit_df["recording_end"], errors="coerce")
fit_df["mri_date"] = pd.to_datetime(fit_df["mri_date"], errors="coerce")
