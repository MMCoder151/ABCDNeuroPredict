# Get list of included subjects
included_subjects = fit_df["subject"].unique()

# import static demographic information
stc_df = pd.read_csv(mri_path / "ab_g_stc.tsv", sep="\t")

# create dataframe with sex and date of birth for included subjects
demo_df = subs[subs["participant_id"].isin(included_subjects)][["participant_id", "sex"]].merge(
    stc_df[stc_df["participant_id"].isin(included_subjects)][["participant_id", "ab_g_stc__cohort_dob"]],
    on="participant_id",
    how="left"
)
demo_df.rename(columns={"ab_g_stc__cohort_dob": "date_of_birth"}, inplace=True)
print(demo_df)

# add sex and age at MRI scan (rounded to nearest year) per subject and timepoint to fit_df
fit_df = fit_df.merge(demo_df, left_on="subject", right_on="participant_id", how="left")
fit_df["date_of_birth"] = pd.to_datetime(fit_df["date_of_birth"], errors="coerce")
fit_df["age_at_mri"] = (fit_df["mri_date"] - fit_df["date_of_birth"]).dt.days / 365.25
fit_df["age_at_mri"] = fit_df["age_at_mri"].round()
print(fit_df[["subject", "timepoint", "sex", "age_at_mri"]])

# create summary table per subject per timepoint
summary_table = fit_df.groupby(["subject", "timepoint"]).agg(
    sex=("sex", "first"),
    recording_start_min=("recording_start", "min"),
    recording_start_max=("recording_start", "max"),
    recording_start_diff=("recording_start_diff", "max"),
    recording_end_min=("recording_end", "min"),
    recording_end_max=("recording_end", "max"),
    recording_end_diff=("recording_end_diff", "max"),
    recording_duration_min=("recording_duration", "min"),
    recording_duration_max=("recording_duration", "max"),
    recording_duration_diff=("recording_duration_diff", "max"),
    mri_date=("mri_date_date", "first"),
    age_at_mri=("age_at_mri", "min"),
    time_to_mri_O=("time_to_mri", "max"),
    time_to_mri_X=("time_to_mri", "min")
).reset_index()
# save summary table to output directory
summary_table.to_csv(os.path.join(output_path, "fit_scan_summary.csv"), index=False)

