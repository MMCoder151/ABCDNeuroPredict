# print subjects and timepoints and count of deviating files
deviating_recording_duration_files_max["count"] = deviating_recording_duration_files_max["deviating_files_max"].apply(len)
print(deviating_recording_duration_files_max[["subject", "timepoint", "count"]])

# print file names with minimum recording duration per subject and timepoint
min_recording_duration_files = fit_df.groupby(["subject", "timepoint"])["filename"].apply(lambda x: x[fit_df.loc[x.index, "recording_duration"] == fit_df.loc[x.index, "recording_duration"].min()]).reset_index()
min_recording_duration_files.rename(columns={"filename": "min_recording_duration_file"}, inplace=True)
print(min_recording_duration_files)

