fit_df["deviating_recording_duration_file_max"] = fit_df.apply(lambda row: row["filename"] if row["recording_duration"] != row["max_recording_duration"] else None, axis=1)
# Collect deviating filenames per group as a list
deviating_recording_duration_files_max = fit_df[fit_df["deviating_recording_duration_file_max"].notna()].groupby(["subject", "timepoint"])["deviating_recording_duration_file_max"].apply(list).reset_index()
